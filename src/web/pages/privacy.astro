---
import MarketingLayout from '../layouts/MarketingLayout.astro';
---

<MarketingLayout title="Privacy Policy" noindex={true}>

  <section class="pt-32 pb-20 px-6">
    <div class="max-w-3xl mx-auto">
      <span class="eyebrow">Legal</span>
      <h1 class="mt-4 text-4xl font-extrabold tracking-tight">Privacy Policy</h1>
      <p class="mt-4 text-text-dim">Last updated: May 2026</p>
    </div>
  </section>

  <section class="pb-20 px-6">
    <div class="max-w-3xl mx-auto space-y-8">

      <div class="glass rounded-2xl p-6 md:p-8">
        <h2 class="text-xl font-bold mb-3">Scope</h2>
        <p class="text-text-dim leading-relaxed">
          This policy covers the gpui-starter website at
          <code class="text-sm bg-amber/10 text-amber px-1.5 py-0.5 rounded border border-amber/20">gpui-starter.hmziq.xyz</code>.
          The desktop application itself runs entirely locally on your machine and does not
          communicate with any servers.
        </p>
      </div>

      <div class="glass rounded-2xl p-6 md:p-8">
        <h2 class="text-xl font-bold mb-3">Data we collect</h2>
        <p class="text-text-dim leading-relaxed">
          <strong class="text-text">None.</strong> This website does not use analytics, tracking
          scripts, cookies, or any form of data collection. We don't track page views, clicks,
          or user behavior.
        </p>
      </div>

      <div class="glass rounded-2xl p-6 md:p-8">
        <h2 class="text-xl font-bold mb-3">Data we don't collect</h2>
        <ul class="text-text-dim leading-relaxed space-y-2">
          <li>No personal information</li>
          <li>No usage or analytics data</li>
          <li>No IP addresses or location data</li>
          <li>No cookies or local storage tracking</li>
          <li>No cross-site tracking</li>
          <li>No third-party advertising</li>
        </ul>
      </div>

      <div class="glass rounded-2xl p-6 md:p-8">
        <h2 class="text-xl font-bold mb-3">Third-party services</h2>
        <p class="text-text-dim leading-relaxed">
          This website loads fonts from <strong class="text-text">Google Fonts</strong>
          (fonts.googleapis.com). Google may collect your IP address when loading these fonts.
          See <a href="https://policies.google.com/privacy" target="_blank" rel="noopener" class="text-amber hover:text-amber-bright transition-colors">Google's Privacy Policy</a>.
        </p>
        <p class="text-text-dim leading-relaxed mt-3">
          The source code is hosted on <strong class="text-text">GitHub</strong>. Their privacy policy applies when visiting github.com.
        </p>
      </div>

      <div class="glass rounded-2xl p-6 md:p-8">
        <h2 class="text-xl font-bold mb-3">Your rights</h2>
        <p class="text-text-dim leading-relaxed">
          Under GDPR, CCPA, and similar regulations, you have the right to access, correct,
          and delete your personal data. Since we collect no data, there is nothing to access
          or delete.
        </p>
      </div>

      <div class="glass rounded-2xl p-6 md:p-8">
        <h2 class="text-xl font-bold mb-3">Changes to this policy</h2>
        <p class="text-text-dim leading-relaxed">
          We may update this page from time to time. The "Last updated" date at the top
          reflects the most recent revision.
        </p>
      </div>

      <div class="glass rounded-2xl p-6 md:p-8">
        <h2 class="text-xl font-bold mb-3">Contact</h2>
        <p class="text-text-dim leading-relaxed">
          Questions? Open an issue at
          <a href="https://github.com/hmziqrs/gpui-app/issues" target="_blank" rel="noopener" class="text-amber hover:text-amber-bright transition-colors">github.com/hmziqrs/gpui-app/issues</a>.
        </p>
      </div>

    </div>
  </section>

</MarketingLayout>
