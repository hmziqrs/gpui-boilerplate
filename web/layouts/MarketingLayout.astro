---
import { latestVersion } from '../util/changelog';

interface Props {
  title?: string;
  description?: string;
  ogType?: 'website' | 'article';
  ogImage?: string;
  articlePublishedTime?: Date;
  articleTags?: string[];
  jsonLd?: Record<string, unknown>;
  noindex?: boolean;
}

const SITE = 'https://gpui-starter.hmziq.xyz';
const DEFAULT_TITLE = 'gpui-starter: Build desktop apps with GPUI';
const DEFAULT_DESC =
  'A production-ready Rust boilerplate for GPUI desktop apps. Themes, i18n, forms, command launcher, and more.';
const DEFAULT_OG_IMAGE = `${SITE}/og-image.svg`;

const {
  title = DEFAULT_TITLE,
  description = DEFAULT_DESC,
  ogType = 'website',
  ogImage = DEFAULT_OG_IMAGE,
  articlePublishedTime,
  articleTags = [],
  jsonLd: customJsonLd,
  noindex = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, SITE).toString();
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${SITE}${ogImage}`;

const crumbs = Astro.url.pathname
  .split('/')
  .filter(Boolean)
  .map((seg, i, arr) => ({
    name: seg.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase()),
    url: '/' + arr.slice(0, i + 1).join('/') + '/',
  }));

const schemaApp = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'gpui-starter',
  url: SITE,
  description: DEFAULT_DESC,
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'macOS, Linux, Windows',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  author: { '@type': 'Person', name: 'hmziqrs', url: 'https://hmziq.rs' },
  license: 'https://opensource.org/licenses/MIT',
  codeRepository: 'https://github.com/hmziqrs/gpui-boilerplate',
  programmingLanguage: 'Rust',
};

const schemaBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE },
    ...crumbs.map((c, i) => ({
      '@type': 'ListItem',
      position: i + 2,
      name: c.name,
      item: `${SITE}${c.url}`,
    })),
  ],
};

const jsonLdArray = [schemaApp, schemaBreadcrumb];
if (customJsonLd) jsonLdArray.push(customJsonLd);
