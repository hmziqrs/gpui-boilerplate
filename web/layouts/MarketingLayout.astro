    <script>
      // ---------- Scroll progress ----------
      const progress = document.getElementById('scroll-progress');
      function updateProgress() {
        const h = document.documentElement;
        const pct = (h.scrollTop / (h.scrollHeight - h.clientHeight)) * 100;
        if (progress) progress.style.width = pct + '%';
      }
      window.addEventListener('scroll', updateProgress, { passive: true });

      // ---------- Reveal on scroll ----------
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add('visible');
              io.unobserve(e.target);
            }
          }
        },
        { threshold: 0, rootMargin: '0px 0px -10% 0px' }
      );
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));

      // ---------- Three.js: wireframe geometry structures ----------
      async function initThree() {
        const THREE = await import('three');
        const AMBER_C = 0xf59e0b;
        const GOLD_C  = 0xfbbf24;
        const DEEP_C  = 0xd97706;

        function makeScene(host, builder) {
          const canvas = document.createElement('canvas');
          canvas.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;pointer-events:none;display:block;';
          host.appendChild(canvas);
          const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
          renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
          const scene = new THREE.Scene();
          const camera = new THREE.PerspectiveCamera(40, 1, 0.1, 100);
          camera.position.z = 5;
          const group = new THREE.Group();
          scene.add(group);
          const ctx = { THREE, scene, camera, renderer, group };
          let tickFn = null;
          ctx.onTick = (fn) => { tickFn = fn; };
          
          // Reveal animation tracking
          const trackedMaterials = [];
          ctx.trackMaterial = (mat, targetOpacity) => {
            trackedMaterials.push({ mat, target: targetOpacity, startTime: -1 });
          };
          
          let hovered = false;
          host.addEventListener('mouseenter', () => { hovered = true; });
          host.addEventListener('mouseleave', () => { hovered = false; });
          builder(ctx);
          let lastW = 0, lastH = 0;
          function resize() {
            const w = host.clientWidth || 1;
            const h = host.clientHeight || 1;
            if (w === lastW && h === lastH) return;
            lastW = w; lastH = h;
            renderer.setSize(w, h, false);
            canvas.width = w * renderer.getPixelRatio();
            canvas.height = h * renderer.getPixelRatio();
            canvas.style.width = w + 'px';
            canvas.style.height = h + 'px';
            camera.aspect = w / h;
            camera.updateProjectionMatrix();
          }
          resize();
          const ro = new ResizeObserver(resize);
          ro.observe(host);
          setTimeout(() => ro.disconnect(), 600);
          let visible = true;
          let revealed = false;
          let revealTime = 0;
          const revealObserver = new IntersectionObserver(([e]) => {
            visible = e.isIntersecting;
            if (e.isIntersecting && !revealed) {
              revealed = true;
              revealTime = t;
            }
          }, { threshold: 0.1 });
          revealObserver.observe(host);
          let t = 0;
          (function loop() {
            requestAnimationFrame(loop);
            if (!visible) return;
            if (!hovered) t += 0.016;
            
            // Animate tracked materials with staggered reveal
            if (revealed && trackedMaterials.length > 0) {
              const elapsed = t - revealTime;
              trackedMaterials.forEach((item, i) => {
                const delay = i * 0.08; // 80ms stagger
                const matElapsed = Math.max(0, elapsed - delay);
                const duration = 0.6;
                const progress = Math.min(1, matElapsed / duration);
                // Ease out cubic
                const eased = 1 - Math.pow(1 - progress, 3);
                item.mat.opacity = item.target * eased;
              });
            }
            
            if (tickFn) {
              tickFn(t, group);
            } else {
              group.rotation.y = t * 0.1;
              group.rotation.x = Math.sin(t * 0.06) * 0.12;
            }
            renderer.render(scene, camera);
          })();
        }

        // Helper: add a wireframe mesh with amber lines
        function addWire(ctx, geometry, color, opacity) {
          const targetOpacity = opacity || 0.35;
          const mat = new ctx.THREE.MeshBasicMaterial({
            color, wireframe: true, transparent: true, opacity: 0
          });
          const mesh = new ctx.THREE.Mesh(geometry, mat);
          ctx.group.add(mesh);
          if (ctx.trackMaterial) ctx.trackMaterial(mat, targetOpacity);
          return mesh;
        }

        // Helper: add a LineSegments from pairs of [x,y,z]
        function addLines(ctx, pairs, color, opacity) {
          const targetOpacity = opacity || 0.4;
          const verts = [];
          pairs.forEach(([a, b]) => { verts.push(...a, ...b); });
          const geo = new ctx.THREE.BufferGeometry();
          geo.setAttribute('position', new ctx.THREE.Float32BufferAttribute(verts, 3));
          const mat = new ctx.THREE.LineBasicMaterial({ color, transparent: true, opacity: 0 });
          ctx.group.add(new ctx.THREE.LineSegments(geo, mat));
          if (ctx.trackMaterial) ctx.trackMaterial(mat, targetOpacity);
        }

        // Helper: add small dots at positions
        function addDots(ctx, positions, color, opacity, size) {
          const targetOpacity = opacity || 0.8;
          const geo = new ctx.THREE.BufferGeometry();
          geo.setAttribute('position', new ctx.THREE.Float32BufferAttribute(positions, 3));
          const mat = new ctx.THREE.PointsMaterial({
            color, transparent: true, opacity: 0,
            size: size || 0.06, sizeAttenuation: true
          });
          ctx.group.add(new ctx.THREE.Points(geo, mat));
          if (ctx.trackMaterial) ctx.trackMaterial(mat, targetOpacity);
        }

        // ===== 1. HERO — Lattice cube with build animation =====
        const heroHost = document.querySelector('[data-three="hero-glyph"]');
        if (heroHost)
          makeScene(heroHost, (ctx) => {
            ctx.camera.position.z = 6;
            const d = 1.5;
            const items = [];

            let mouseX = 0, mouseY = 0, smoothMX = 0, smoothMY = 0;
            let clickPulse = 0;
            heroHost.addEventListener('mousemove', (e) => {
              const r = heroHost.getBoundingClientRect();
              mouseX = ((e.clientX - r.left) / r.width - 0.5) * 2;
              mouseY = ((e.clientY - r.top) / r.height - 0.5) * 2;
            });
            heroHost.addEventListener('mouseleave', () => { mouseX = 0; mouseY = 0; });
            heroHost.addEventListener('click', () => { clickPulse = 1.0; });

            function track(mat, target, start, dur) {
              mat.opacity = 0;
              items.push({ mat, target, start, dur });
            }

            function dot(pos, color, size, target, start, dur) {
              // Create glow texture with strong white shine
              const canvas = document.createElement('canvas');
              canvas.width = 64;
              canvas.height = 64;
              const ctx2d = canvas.getContext('2d');
              const gradient = ctx2d.createRadialGradient(32, 32, 0, 32, 32, 32);
              gradient.addColorStop(0, 'rgba(255, 255, 255, 1)');
              gradient.addColorStop(0.15, 'rgba(255, 255, 255, 1)');
              gradient.addColorStop(0.3, 'rgba(255, 255, 255, 0.9)');
              gradient.addColorStop(0.5, `rgba(${(color >> 16) & 255}, ${(color >> 8) & 255}, ${color & 255}, 0.5)`);
              gradient.addColorStop(0.75, `rgba(${(color >> 16) & 255}, ${(color >> 8) & 255}, ${color & 255}, 0.2)`);
              gradient.addColorStop(1, 'rgba(0, 0, 0, 0)');
              ctx2d.fillStyle = gradient;
              ctx2d.fillRect(0, 0, 64, 64);
              const texture = new ctx.THREE.CanvasTexture(canvas);

              // Shiny glow sprite
              const mat = new ctx.THREE.PointsMaterial({
                color: 0xffffff,
                map: texture,
                transparent: true,
                opacity: 0,
                size: size * 6,
                sizeAttenuation: true,
                blending: ctx.THREE.AdditiveBlending,
                depthWrite: false,
                alphaTest: 0.01
              });
              const geo = new ctx.THREE.BufferGeometry();
              geo.setAttribute('position', new ctx.THREE.Float32BufferAttribute(pos, 3));
              const points = new ctx.THREE.Points(geo, mat);
              ctx.group.add(points);
              track(mat, target, start, dur);
            }

            function line(a, b, color, target, start, dur) {
              const verts = [...a, ...b];
              const geo = new ctx.THREE.BufferGeometry();
              geo.setAttribute('position', new ctx.THREE.Float32BufferAttribute(verts, 3));
              const mat = new ctx.THREE.LineBasicMaterial({
                color, transparent: true, opacity: 0,
                blending: ctx.THREE.AdditiveBlending
              });
              ctx.group.add(new ctx.THREE.LineSegments(geo, mat));
              track(mat, target, start, dur);
            }

            const c = [];
            for (let x = -1; x <= 1; x += 2)
              for (let y = -1; y <= 1; y += 2)
                for (let z = -1; z <= 1; z += 2)
                  c.push([x * d, y * d, z * d]);

            c.forEach((pos, i) => {
              dot(pos, GOLD_C, 0.07, 1.0, i * 0.3, 0.9);
            });

            const edgeIdx = [
