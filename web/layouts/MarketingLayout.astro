                const ease = Math.min(1, rt / 1.5);
                group.rotation.y = rt * 0.1 * ease;
                group.rotation.x = Math.sin(rt * 0.06) * 0.12 * ease;
              }
            });
          },
        };

        document.querySelectorAll('[data-three="feature-shape"]').forEach((host) => {
          const kind = host.getAttribute('data-shape') || 'ico';
          makeScene(host, (ctx) => {
            ctx.camera.position.z = 3.6;
            (structures[kind] || structures.ico)(ctx);
          });
        });

        // ===== 4. CTA — Icosahedron wireframe with build animation =====
        const ctaHost = document.querySelector('[data-three="cta-shape"]');
        if (ctaHost)
          makeScene(ctaHost, (ctx) => {
            ctx.camera.position.z = 5.5;
            const items = [];
            let revealed = false;
            let buildStart = 0;

            function track(mat, target, start, dur) {
              mat.opacity = 0;
              items.push({ mat, target, start, dur });
            }

            // Outer icosahedron wireframe
            const outerGeo = new ctx.THREE.IcosahedronGeometry(2.0, 0);
            const outerMat = new ctx.THREE.MeshBasicMaterial({
              color: AMBER_C, wireframe: true, transparent: true, opacity: 0,
              blending: ctx.THREE.AdditiveBlending
            });
            ctx.group.add(new ctx.THREE.Mesh(outerGeo, outerMat));
            track(outerMat, 0.25, 0, 1.5);

            // Inner dodecahedron
            const innerGeo = new ctx.THREE.DodecahedronGeometry(1.0, 0);
            const innerMat = new ctx.THREE.MeshBasicMaterial({
              color: GOLD_C, wireframe: true, transparent: true, opacity: 0,
              blending: ctx.THREE.AdditiveBlending
            });
            ctx.group.add(new ctx.THREE.Mesh(innerGeo, innerMat));
            track(innerMat, 0.15, 0.8, 1.5);

            // Vertex dots on outer
            const dotsGeo = new ctx.THREE.BufferGeometry();
            dotsGeo.setAttribute('position', outerGeo.attributes.position);
            const dotsMat = new ctx.THREE.PointsMaterial({
              color: GOLD_C, transparent: true, opacity: 0,
              size: 0.08, sizeAttenuation: true,
              blending: ctx.THREE.AdditiveBlending, depthWrite: false
            });
            ctx.group.add(new ctx.THREE.Points(dotsGeo, dotsMat));
            track(dotsMat, 0.9, 1.5, 1.0);

            const BUILD_END = 3.0;
            ctx.onTick((t, group) => {
              if (!revealed) {
                revealed = true;
                buildStart = t;
              }
              const elapsed = t - buildStart;

              for (const item of items) {
                const p = Math.max(0, Math.min(1, (elapsed - item.start) / item.dur));
                item.mat.opacity = item.target * (1 - Math.pow(1 - p, 3));
              }

              if (elapsed > BUILD_END) {
                const rt = elapsed - BUILD_END;
                const ease = Math.min(1, rt / 1.5);
                group.rotation.y = rt * 0.12 * ease;
                group.rotation.x = Math.sin(rt * 0.07) * 0.1 * ease;
              }
            });
          });
      }
      initThree();
    </script>
  </body>
</html>
