---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/MarketingLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('faq');
  const sorted = entries.sort((a, b) => a.data.order - b.data.order);
  return sorted.map((entry, i) => ({
    params: { slug: entry.id },
    props: {
      entry,
      prev: i > 0 ? sorted[i - 1] : null,
      next: i < sorted.length - 1 ? sorted[i + 1] : null,
    },
  }));
}

const { entry, prev, next } = Astro.props;
const { Content } = await render(entry);

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: {
    '@type': 'Question',
    name: entry.data.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: entry.data.description,
    },
  },
};
---

<Layout
  title={`${entry.data.question} - gpui-starter FAQ`}
  description={entry.data.description}
  jsonLd={faqJsonLd}
>
  <article class="relative z-10 pt-36 pb-24 px-6">
    <div class="max-w-3xl mx-auto">
      <a
        href="/faq/"
        class="text-sm text-text-mute no-underline hover:text-amber inline-flex items-center gap-1.5 mb-8"
      >
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="m12 19-7-7 7-7"></path>
          <path d="M19 12H5"></path>
        </svg>
        Back to FAQ
      </a>

      <span class="text-xs font-mono uppercase tracking-[0.2em] text-amber mb-4 block">
        {entry.data.category}
      </span>

      <h1 class="text-3xl sm:text-4xl font-extrabold tracking-[-0.02em] leading-[1.1] mb-5">
        {entry.data.question}
      </h1>

      <p class="text-lg text-text-dim leading-relaxed mb-10">
        {entry.data.description}
      </p>

      <div class="prose-faq">
        <Content />
      </div>

      <div class="mt-16 pt-8 border-t border-edge grid grid-cols-2 gap-4">
        {prev ? (
          <a
            href={`/faq/${prev.id}/`}
            class="glass rounded-xl p-4 no-underline group"
          >
            <span class="text-xs text-text-mute font-mono block mb-1">Previous</span>
            <span class="text-sm font-semibold group-hover:text-amber transition-colors text-text-dim">
              {prev.data.question}
            </span>
          </a>
        ) : <div />}
        {next ? (
          <a
            href={`/faq/${next.id}/`}
            class="glass rounded-xl p-4 no-underline text-right group"
          >
            <span class="text-xs text-text-mute font-mono block mb-1">Next</span>
            <span class="text-sm font-semibold group-hover:text-amber transition-colors text-text-dim">
              {next.data.question}
            </span>
          </a>
        ) : <div />}
      </div>
    </div>
  </article>
</Layout>

<style is:global>
  .prose-faq {
    color: var(--color-text-dim);
    font-size: 1.05rem;
    line-height: 1.75;
  }
  .prose-faq h2 {
    color: var(--color-text);
    font-size: 1.5rem;
    font-weight: 700;
    margin-top: 2.5rem;
    margin-bottom: 0.85rem;
  }
  .prose-faq h3 {
    color: var(--color-text);
    font-size: 1.2rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .prose-faq p {
    margin-bottom: 1.15rem;
  }
  .prose-faq a {
    color: var(--color-amber);
    text-decoration: none;
    border-bottom: 1px solid rgba(245, 158, 11, 0.3);
    transition: border-color 0.15s;
  }
  .prose-faq a:hover {
    border-bottom-color: var(--color-amber);
  }
  .prose-faq code {
    font-family: var(--font-mono);
    font-size: 0.92em;
    color: var(--color-amber);
    background: rgba(245, 158, 11, 0.08);
    padding: 0.12rem 0.4rem;
    border-radius: 0.3rem;
  }
  .prose-faq pre {
    background: rgba(10, 10, 14, 0.85);
    border: 1px solid var(--color-edge);
    border-radius: 0.85rem;
    padding: 1.1rem 1.25rem;
    overflow-x: auto;
    margin: 1.5rem 0;
    font-size: 0.88rem;
    line-height: 1.6;
  }
  .prose-faq pre code {
    background: none;
    padding: 0;
    color: inherit;
    font-size: inherit;
  }
  .prose-faq ul,
  .prose-faq ol {
    padding-left: 1.5rem;
    margin-bottom: 1.15rem;
  }
  .prose-faq li {
    margin-bottom: 0.35rem;
  }
  .prose-faq blockquote {
    border-left: 3px solid var(--color-amber);
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: var(--color-text-mute);
    font-style: italic;
  }
  .prose-faq hr {
    border: none;
    border-top: 1px solid var(--color-edge);
    margin: 2rem 0;
  }
  .prose-faq strong {
    color: var(--color-text);
    font-weight: 600;
  }
  .prose-faq table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.25rem 0;
  }
  .prose-faq th,
  .prose-faq td {
    text-align: left;
    padding: 0.6rem 0.8rem;
    border-bottom: 1px solid var(--color-edge);
    font-size: 0.9rem;
  }
  .prose-faq th {
    color: var(--color-text);
    font-weight: 600;
  }
</style>
