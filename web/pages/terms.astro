---
import MarketingLayout from '../layouts/MarketingLayout.astro';
---

<MarketingLayout title="Terms of Use" description="Terms of use for gpui-starter. MIT license, no warranty, third-party providers, and API cost responsibilities." noindex={true}>

  <section class="pt-32 pb-20 px-6">
    <div class="max-w-3xl mx-auto">
      <span class="eyebrow">Legal</span>
      <h1 class="mt-4 text-4xl font-extrabold tracking-tight">Terms of Use</h1>
      <p class="mt-4 text-text-dim">Last updated: May 2026</p>
    </div>
  </section>

  <section class="pb-20 px-6">
    <div class="max-w-3xl mx-auto space-y-8">

      <div class="glass rounded-2xl p-6 md:p-8">
        <h2 class="text-xl font-bold mb-3">Acceptance</h2>
        <p class="text-text-dim leading-relaxed">
          By using gpui-starter or this website, you accept these terms. If you disagree,
          don't use the software.
        </p>
      </div>

      <div class="glass rounded-2xl p-6 md:p-8">
        <h2 class="text-xl font-bold mb-3">The software</h2>
        <p class="text-text-dim leading-relaxed">
          gpui-starter is released under the
          <a href="https://opensource.org/licenses/MIT" target="_blank" rel="noopener" class="text-amber hover:text-amber-bright transition-colors">MIT License</a>.
          You are free to use, copy, modify, merge, publish, distribute, sublicense, and/or sell
          copies of the software. The only requirement is that the copyright notice and permission
          notice be included in all copies or substantial portions of the software.
        </p>
      </div>

      <div class="glass rounded-2xl p-6 md:p-8">
        <h2 class="text-xl font-bold mb-3">No warranty</h2>
        <p class="text-text-dim leading-relaxed">
          The software is provided "as is", without warranty of any kind, express or implied.
          In no event shall the authors or copyright holders be liable for any claim, damages,
          or other liability arising from the software or its use.
        </p>
      </div>

      <div class="glass rounded-2xl p-6 md:p-8">
        <h2 class="text-xl font-bold mb-4">Third-party dependencies</h2>
        <p class="text-text-dim leading-relaxed mb-4">
          gpui-starter depends on and is grateful for these open-source projects:
        </p>
        <div class="grid sm:grid-cols-2 gap-3">
          <div class="p-3 rounded-lg bg-surface border border-edge">
            <div class="text-sm font-bold">GPUI</div>
            <div class="text-xs text-text-mute">by Zed Industries — GPU-accelerated UI framework</div>
          </div>
          <div class="p-3 rounded-lg bg-surface border border-edge">
            <div class="text-sm font-bold">gpui-component</div>
            <div class="text-xs text-text-mute">by Longbridge — UI component library for GPUI</div>
          </div>
          <div class="p-3 rounded-lg bg-surface border border-edge">
            <div class="text-sm font-bold">es-fluent</div>
            <div class="text-xs text-text-mute">Fluent localization system for Rust</div>
          </div>
          <div class="p-3 rounded-lg bg-surface border border-edge">
            <div class="text-sm font-bold">koruma</div>
            <div class="text-xs text-text-mute">Composable validation with derive macros</div>
          </div>
        </div>
      </div>

      <div class="glass rounded-2xl p-6 md:p-8">
        <h2 class="text-xl font-bold mb-3">Your responsibilities</h2>
        <ul class="text-text-dim leading-relaxed space-y-2">
          <li>What you build with gpui-starter is yours — you own your code</li>
          <li>Don't use it for anything illegal</li>
          <li>Respect the licenses of dependencies you include</li>
          <li>The software is provided by an independent developer, not a company</li>
        </ul>
      </div>

      <div class="glass rounded-2xl p-6 md:p-8">
        <h2 class="text-xl font-bold mb-3">Trademarks</h2>
        <p class="text-text-dim leading-relaxed">
          GPUI is a trademark of Zed Industries, Inc. gpui-starter is not affiliated with,
          endorsed by, or connected to Zed Industries. All other trademarks belong to their
          respective owners.
        </p>
      </div>

      <div class="glass rounded-2xl p-6 md:p-8">
        <h2 class="text-xl font-bold mb-3">Modifications</h2>
        <p class="text-text-dim leading-relaxed">
          These terms may change. Continued use after changes constitutes acceptance of the
          updated terms.
        </p>
      </div>

      <div class="glass rounded-2xl p-6 md:p-8">
        <h2 class="text-xl font-bold mb-3">Contact</h2>
        <p class="text-text-dim leading-relaxed">
          Questions? Open an issue at
          <a href="https://github.com/hmziqrs/gpui-boilerplate/issues" target="_blank" rel="noopener" class="text-amber hover:text-amber-bright transition-colors">github.com/hmziqrs/gpui-boilerplate/issues</a>.
        </p>
      </div>

    </div>
  </section>

</MarketingLayout>
